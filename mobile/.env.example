# =============================================================================
# MOBILE ENVIRONMENT VARIABLES (.env.example)
# =============================================================================

# --- API Configuration ---
# Base URL for the Backend API REST
# Note: Use your machine's local IP (e.g., http://192.168.1.XX:3000) for physical device testing
API_URL="http://localhost:3000/api"

# Base URL for Socket.io connections
# Note: Usually same as API_URL but without the '/api' suffix
SOCKET_URL="http://localhost:3000"

# Alternative variable names if using older Expo versions or specific build tools
EXPO_PUBLIC_API_URL="http://localhost:3000/api"

# --- Stripe Payments ---
# Your Stripe Publishable Key from the Dashboard (pk_test_...)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_51..."

# --- Maps & Location ---
# API Key for Google Maps (Required for Android/iOS native builds)
# Not strictly required for Expo Go if using default providers, but recommended
Maps_API_KEY="AIzaSy..."

# --- Build Configuration ---
# Environment mode
NODE_ENV=development
