{
  "name": "temp-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "npx expo start ",
    "start--local": "npx expo start   --localhost",
    "start:prod": "NODE_ENV=production expo start",
    "refresh adb": "adb kill-server && adb start-server ",
    "build": "eas build --profile production",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build -p android --profile preview ",
    "build:simulator": "eas build  --profile development-simulator ",
    "test dev": "jest --watch --coverage=false --changedSince=origin/master",
    "test": "jest",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "eject": "npx expo eject",
    "update:preview": "eas update --channel preview",
    "publish": "eas submit --profile production",
    "open react devtools": "adb shell input keyevent 82",
    "devtools": "npx react-devtools",
    "updateSnapshots": "jest -u --coverage=false",
    "lint": "eslint . --fix ",
    "build:android": "NODE_ENV=production eas build -p android",
    "build:ios": "NODE_ENV=production eas build -p ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-community/slider": "5.1.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/stack": "^7.8.5",
    "@reduxjs/toolkit": "^2.11.2",
    "@stripe/stripe-react-native": "^0.58.0",
    "axios": "^1.13.6",
    "expo": "~55.0.8",
    "expo-dev-client": "~55.0.18",
    "expo-device": "^55.0.10",
    "expo-notifications": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "iconsax-react-native": "^0.0.8",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-redux": "^9.2.0",
    "socket.io-client": "^4.8.3"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.73.0",
    "@types/react-redux": "^7.1.34",
    "typescript": "^5.9.3"
  }
}