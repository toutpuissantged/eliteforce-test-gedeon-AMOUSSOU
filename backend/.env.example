# =============================================================================
# BACKEND ENVIRONMENT VARIABLES (.env.example)
# =============================================================================

# --- Server Configuration ---
# Port on which the Express server will run
PORT=3000
# Environment mode (development, production, test)
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Prisma database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:password@localhost:5432/eliteforce?schema=public"

# --- Security & Authentication ---
# Secret key for signing JWT tokens (Use a long random string in production)
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production"
# JWT expiration time (e.g., 1h, 7d, 30d)
JWT_EXPIRES_IN="7d"

# --- Stripe Payments ---
# Your Stripe Secret Key from the Dashboard (sk_test_...)
STRIPE_SECRET_KEY="sk_test_51..."
# Your Stripe Webhook Secret for local testing (use 'stripe listen' CLI to get this)
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Cross-Origin Resource Sharing (CORS) ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:19000,http://localhost:8081,exp://localhost:8081"

# --- Expo Push Notifications (Optional) ---
# Access token if you are using Expo Application Services (EAS) for push
# EXPO_ACCESS_TOKEN="your_expo_access_token"
